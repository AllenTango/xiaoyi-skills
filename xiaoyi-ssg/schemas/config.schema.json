{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "xiaoyi-ssg Config Schema Template",
  "description": "pages 仅表示内容类型启用/排序，渲染表现由 template-manifest.json 决定。theme 字段已废弃（设计 tokens 由 .xiaoyi-ssg-design-tokens.json 管理）。",
  "type": "object",
  "required": [
    "site",
    "pages"
  ],
  "properties": {
    "site": {
      "type": "object",
      "required": [
        "title",
        "author"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "subtitle": {
          "type": "string"
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
          "description": "BCP 47 language tag. 推断自用户请求语言，除非用户明确指定其他语言。"
        },
        "timezone": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "output_dir": {
      "type": "string",
      "default": "public"
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "启用的内容类型（按 nav 顺序）。仅表示内容类型启用/排序，**导航表现由 template-manifest.json + 模板决定**。"
    },
    "nav": {
      "type": "object",
      "description": "导航元数据。基础信息由 config 提供，模板可自由组合更多导航元素。",
      "properties": {
        "home_title": {
          "type": "string",
          "default": "Home"
        },
        "external_links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "title",
              "url"
            ],
            "properties": {
              "title": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "target": {
                "type": "string",
                "enum": [
                  "_blank",
                  "_self"
                ]
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": {
    "type": "object",
    "description": "每内容类型覆盖项。大部分字段已废弃，仅保留向后兼容字段。"
  }
}