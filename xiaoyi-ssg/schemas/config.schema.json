{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "xiaoyi-ssg site config",
  "type": "object",
  "required": ["site"],
  "properties": {
    "site": {
      "type": "object",
      "required": ["title", "language"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "author": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "language": { "type": "string", "pattern": "^[a-z]{2,3}(-[A-Z]{2})?$" },
        "timezone": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "design": {
          "type": "object",
          "properties": {
            "brand": { "type": "string" },
            "source_skill": { "type": "string" }
          }
        },
        "build": {
          "type": "object",
          "description": "Build-time overrides. Default output_dir is `public/`. When a user is migrating from an existing static site generator (Hugo / Jekyll / Astro / Next-static-export / etc.) whose `public/` / `_site/` / `dist/` / `out/` directory already exists, the AI must use `.xiaoyi-ssg-build/` instead to avoid collision. The renderer does not overwrite an existing non-empty output directory.",
          "properties": {
            "per_page": { "type": "number", "default": 10 },
            "output_dir": { "type": "string", "default": "public" }
          }
        }
      }
    },
    "pages": { "type": "array" },
    "nav": { "type": "array" },
    "social": { "type": "array" }
  }
}
